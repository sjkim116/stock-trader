# Terraform
infrastructure/terraform/**/.terraform/
infrastructure/terraform/**/terraform.tfstate
infrastructure/terraform/**/terraform.tfstate.backup
infrastructure/terraform/**/*.tfplan
# Note: .terraform.lock.hcl IS committed for provider version reproducibility.
# Note: environments/<env>/terraform.tfvars IS committed (env-specific config, no secrets).
# Anything with secrets must end in `.secret.tfvars` (ignored below).
infrastructure/terraform/**/*.secret.tfvars
infrastructure/terraform/**/*.auto.tfvars

