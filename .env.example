# AlgoTrader Pro - Environment Variables (Example)
# Copy this file to .env and fill in your actual values

# ============================================
# General
# ============================================
ENVIRONMENT=development  # development, staging, production
PROJECT_NAME=algotrader
AWS_REGION=ap-northeast-2

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://algotrader:dev_password_change_me@localhost:5432/algotrader
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# Redis
# ============================================
REDIS_URL=redis://:dev_password_change_me@localhost:6379
REDIS_TTL=3600  # seconds

# ============================================
# AWS Services
# ============================================
# AWS Credentials (for local development only - use IAM roles in production)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# AWS Cognito
COGNITO_USER_POOL_ID=your_user_pool_id
COGNITO_CLIENT_ID=your_client_id
COGNITO_REGION=ap-northeast-2

# AWS Secrets Manager
SECRETS_MANAGER_PREFIX=algotrader/

# AWS SQS
SQS_ORDER_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/your-account/algotrader-order-queue

# AWS SNS
SNS_ALERTS_TOPIC_ARN=arn:aws:sns:ap-northeast-2:your-account:algotrader-alerts

# ============================================
# JWT & Security
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================
# Broker APIs (증권사 API)
# ============================================
# 한국투자증권 (KIS)
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_ACCOUNT_NUMBER=your_kis_account_number

# 이베스트투자증권 (Xing)
XING_API_KEY=your_xing_api_key
XING_API_SECRET=your_xing_api_secret
XING_ACCOUNT_NUMBER=your_xing_account_number

# Interactive Brokers
IB_API_KEY=your_ib_api_key
IB_ACCOUNT_NUMBER=your_ib_account_number

# Alpaca
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # paper trading

# ============================================
# Email & Notifications
# ============================================
# AWS SES
SES_SENDER_EMAIL=noreply@algotrader.pro
SES_REGION=ap-northeast-2

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ============================================
# Application Settings
# ============================================
# Risk Management
DEFAULT_STOP_LOSS_PERCENT=2.0
DEFAULT_TAKE_PROFIT_PERCENT=3.0
DAILY_LOSS_LIMIT_PERCENT=3.0
MAX_POSITION_SIZE_PERCENT=20.0

# Trading
ALLOW_REAL_TRADING=false  # Set to true only in production
TRADING_HOURS_KR_START=09:00
TRADING_HOURS_KR_END=15:30
TRADING_HOURS_US_START=09:30
TRADING_HOURS_US_END=16:00

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_ENVIRONMENT=development

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# Monitoring
# ============================================
CLOUDWATCH_LOG_GROUP=/algotrader/development
SENTRY_DSN=your_sentry_dsn_here  # Optional

# ============================================
# Development Tools
# ============================================
# PgAdmin
PGADMIN_EMAIL=admin@algotrader.local
PGADMIN_PASSWORD=admin

# Redis Commander (already in docker-compose.yml)

# ============================================
# Testing
# ============================================
TEST_DATABASE_URL=postgresql://algotrader:dev_password_change_me@localhost:5432/algotrader_test
